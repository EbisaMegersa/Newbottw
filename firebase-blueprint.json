{
  "entities": {
    "User": {
      "title": "User",
      "description": "Stores user progress and referral data",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "balance": { "type": "number" },
        "referralCount": { "type": "number" },
        "referredBy": { "type": "string", "description": "ID of the user who referred this user" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "balance", "referralCount", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile and stats"
    }
  }
}
