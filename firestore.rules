rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.username is string && 
             data.balance is number && 
             data.referralCount is number &&
             (!('referredBy' in data) || data.referredBy is string);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && isValidUser(request.resource.data) &&
                      request.resource.data.createdAt == request.time;
      
      allow update: if isSignedIn() && isValidUser(request.resource.data) &&
                      request.resource.data.updatedAt == request.time &&
                      (
                        // Action: Progress Update (Owner syncing or tapping)
                        (request.resource.data.balance >= resource.data.balance && 
                         request.resource.data.referralCount == resource.data.referralCount &&
                         request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'updatedAt', 'username'])) ||
                         
                        // Action: Referral Reward (System or peer granting bonus)
                        (request.resource.data.balance == resource.data.balance + 50 &&
                         request.resource.data.referralCount == resource.data.referralCount + 1 &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'referralCount', 'updatedAt']))
                      );
    }
  }
}
